#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
UNAME_S="$(uname -s)"
UNAME_M="$(uname -m)"

case "${UNAME_S}" in
  Linux*)   SPECFLOW_OS="linux" ;;
  Darwin*)  SPECFLOW_OS="darwin" ;;
  MINGW*|MSYS*|CYGWIN*) SPECFLOW_OS="windows" ;;
  *)
    echo "Unsupported platform for specFlow hook: ${UNAME_S}" >&2
    exit 1
    ;;
esac

case "${UNAME_M}" in
  x86_64|amd64) SPECFLOW_ARCH="amd64" ;;
  arm64|aarch64) SPECFLOW_ARCH="arm64" ;;
  *)
    echo "Unsupported architecture for specFlow hook: ${UNAME_M}" >&2
    exit 1
    ;;
esac

SPECFLOW_BIN="${REPO_ROOT}/specflow/tooling/bin/specflowctl-${SPECFLOW_OS}-${SPECFLOW_ARCH}"
if [[ "${SPECFLOW_OS}" == "windows" ]]; then
  SPECFLOW_BIN="${SPECFLOW_BIN}.exe"
fi

"${SPECFLOW_BIN}" entry sync --stage --repo-root "${REPO_ROOT}"
